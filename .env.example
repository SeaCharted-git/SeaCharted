# Copy this file to .env and fill in values.
# EXPO_PUBLIC_ prefix means these are inlined into the client bundle at build time.
# Never put secret keys (service-role, private) with this prefix — those must live on a server.

# Supabase — create a project at https://supabase.com/dashboard, then copy from Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Mapbox — create a public token at https://account.mapbox.com/access-tokens/
# Restrict this token to your production domain once you have one.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1I...
